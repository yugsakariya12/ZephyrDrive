# ZephyrDrive Environment Specifications Template
# Rename this file to '.env.local' and supply your active parameters.

# MongoDB Connection String (Atlas Cluster URI or Local Instance)
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=your_mongodb_connection_uri_here

# JWT Signature Encryption Key (Secret String)
# Example: a_very_long_secure_random_string_value
JWT_SECRET=your_jwt_signature_secret_key_here
